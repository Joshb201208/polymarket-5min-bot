# ============================================================
# Polymarket 5-Min Trading Bot — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Mode ---------------------------------------------------
# "paper" = simulated trades (start here)
# "live"  = real money on Polygon
TRADING_MODE=paper

# --- Polymarket API Credentials -----------------------------
# Get these from: https://polymarket.com → Settings → API Keys
API_KEY=
API_SECRET=
API_PASSPHRASE=

# --- Wallet --------------------------------------------------
# Your Polygon wallet private key (needed for live trading + redemption)
# DO NOT share this with anyone
PRIVATE_KEY=
# Your wallet/funder address (0x...)
FUNDER_ADDRESS=
# Signature type: 0=EOA, 1=Magic, 2=Gnosis (default 2)
SIGNATURE_TYPE=2

# --- Telegram Alerts ----------------------------------------
# Your bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Your chat ID
TELEGRAM_CHAT_ID=8451693416

# --- Paper Trading ------------------------------------------
PAPER_BALANCE=500.0

# --- Strategy -----------------------------------------------
# Assets to trade (comma-separated)
ASSETS=BTC,ETH,SOL
# "latency_arb" or "signal_based"
PRIMARY_STRATEGY=latency_arb

# --- Risk Management ----------------------------------------
MAX_POSITION_PCT=0.03
DAILY_LOSS_LIMIT_PCT=0.10
MAX_DRAWDOWN_PCT=0.20
MIN_EDGE_THRESHOLD=0.02
KELLY_FRACTION=0.50

# --- Advanced (optional, defaults are fine) -----------------
# DYNAMIC_FEE_ENABLED=true
# POLYMARKET_WS_ENABLED=true
# POSITION_MERGER_ENABLED=true
# LATE_WINDOW_ENABLED=true
# LATE_WINDOW_ACTIVATION_SECONDS=60
# LATE_WINDOW_ENTRY_MIN=0.90
# LATE_WINDOW_ENTRY_MAX=0.95
